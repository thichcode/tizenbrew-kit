{
  "name": "shortvideo-tv",
  "version": "1.1.5",
  "description": "Public short-video feed player for TizenBrew on Samsung Tizen 3",
  "type": "module",
  "packageType": "app",
  "appName": "ShortVideo TV",
  "appPath": "index.html",
  "keys": [
    "ColorF0Red"
  ],
  "files": [
    "index.html",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tizenbrew-kit dev",
    "build": "npx esbuild src/inject.ts --bundle --minify --target=es2015 --outfile=dist/inject.js",
    "package": "tizenbrew-kit package",
    "doctor": "tizenbrew-kit doctor",
    "pretest": "npx esbuild src/inject.ts --bundle --minify --target=es2015 --outfile=dist/inject.js",
    "test": "vitest run test/package-format.test.ts"
  },
  "keywords": [
    "short-video",
    "public-feed",
    "video-player",
    "tizen",
    "tizenbrew",
    "samsung-tv",
    "tv",
    "remote"
  ],
  "license": "MIT"
}
